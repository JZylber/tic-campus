---
import Home from "../../../../components/sections/home/Home.astro";
import Activities from "../../../../components/sections/activities/Activities.astro";
import Layout from "../../../../layouts/Layout.astro";
import Redos from "../../../../components/sections/redo/Redos.astro";
import Program from "../../../../components/sections/program/Program.astro";
import Material from "../../../../components/sections/material/Material.astro";
import Navbar from "../../../../components/navbar/Navbar.astro";
import Mark from "../../../../components/sections/mark/Mark.astro";
import { fetchTemplateSubjects } from "../../../../scripts/APIcalls/subjectData";
import Queries from "../../../../components/sections/queries/Queries.astro";

export async function getStaticPaths() {
  const templateId = "SH-1";
  const paths = await fetchTemplateSubjects(templateId);
  // Change course to sh1Course to match param name
  return paths.map((path) => {
    return {
      ...path,
      params: {
        ...path.params,
        sh1Course: path.params.course,
        year: path.params.year.toString(),
      },
    };
  });
}

const { subject, sh1Course, year } = Astro.params;
const { dataSheetId } = Astro.props;

const items = [
  { name: "home", icon: "home", title: subject },
  { name: "actividades", icon: "school", title: "Actividades" },
  { name: "reentregas", icon: "refresh", title: "Reentregas" },
  { name: "programa", icon: "event_note", title: "Programa" },
  { name: "material", icon: "construction", title: "Material" },
  { name: "consultas", icon: "support_agent", title: "Consultas" },
];
---

<Layout dataSheetId={dataSheetId}>
  <Navbar course={sh1Course} subject={subject} items={items} />
  <main
    class="relative grow bg-gray-50 border-y sm:border-r lg:border-l border-gray-300 sm:rounded-r-xl lg:rounded-l-xl overflow-hidden"
    x-init={`$store.course.setCourse('${sh1Course}');$store.student.getStudentData('${subject}',${year})`}
  >
    <Home
      subject={subject}
      course={sh1Course}
      position={0}
      year={parseInt(year)}
      presentation={true}
    />
    <Activities
      subject={subject}
      course={sh1Course}
      year={parseInt(year)}
      position={1}
    />
    <Redos
      subject={subject}
      year={parseInt(year)}
      course={sh1Course}
      position={2}
    />
    <Program subject={subject} year={parseInt(year)} position={3} />
    <Material
      subject={subject}
      course={sh1Course}
      year={parseInt(year)}
      position={4}
    />
    <Queries position={5} />
    <Mark
      subject={subject}
      course={sh1Course}
      year={parseInt(year)}
      position={6}
    />
  </main>
</Layout>
