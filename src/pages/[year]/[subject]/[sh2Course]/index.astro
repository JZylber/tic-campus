---
import Layout from "../../../../layouts/Layout.astro";
import { fetchTemplateSubjects } from "../../../../scripts/APIcalls/subjectData";
import Shulian3 from "../../../../components/templates/shulian3.astro";

export async function getStaticPaths() {
  const templateId = "SH-2";
  const paths = await fetchTemplateSubjects(templateId);
  // Change course to sh2Course to match param name
  const cleanPaths = paths.map((path) => {
    return {
      ...path,
      params: {
        subject: path.params.subject,
        year: path.params.year,
        sh2Course: path.params.course,
      },
    };
  });
  return cleanPaths;
}

const { sh2Course, year, subject } = Astro.params;
const { dataSheetId } = Astro.props;
---

<Layout dataSheetId={dataSheetId}>
  <Shulian3
    subject={subject}
    course={sh2Course}
    year={Number(year)}
    dataSheetId={dataSheetId}
  />
</Layout>
