---
import Layout from "../../../../layouts/Layout.astro";
import Toggle from "../../../../components/misc/toggle/Toggle.astro";
import TimetableGrid from "../../../../components/sections/timetable/TimetableGrid.astro";
import { getProyectoLevelPaths } from "../../../../scripts/proyectoLevels";

export async function getStaticPaths() {
  return getProyectoLevelPaths();
}

const { year, level } = Astro.params;
---

<script>
  import setAlpineData from "../../../../scripts/alpine/setAlpineData";
  import proyectoHorarioPageData from "../../../../scripts/alpine/data/proyectoHorarioPage";

  setAlpineData("proyectoHorarioPage", proyectoHorarioPageData);
</script>

<Layout>
  <main
    class="relative grow bg-gray-50 overflow-hidden overflow-y-auto"
    x-data={`proyectoHorarioPage(${Number(year)}, ${Number(level)})`}
  >
    <div class="flex flex-col gap-y-4 px-4 py-4">
      <Toggle
        title="Cuatrimestre"
        xModel="cuatrimestre"
        options="cuatrimestreOptions"
        className="w-full md:w-1/3"
      />
      <TimetableGrid editable={false} personalizedAvailable="personalizedAvailable" />
    </div>
  </main>
</Layout>
