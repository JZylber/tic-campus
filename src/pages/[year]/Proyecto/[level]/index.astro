---
import Layout from "../../../../layouts/Layout.astro";
import Navbar from "../../../../components/navbar/Navbar.astro";
import { getProyectoLevelPaths } from "../../../../scripts/proyectoLevels";

export async function getStaticPaths() {
  return getProyectoLevelPaths();
}

const { level } = Astro.params;
const subject = "Proyecto";

const items = [{ name: "home", icon: "home", title: subject }];
---

<Layout>
  <Navbar course={level} subject={subject} items={items} />
  <main
    class="relative grow bg-gray-50 border-y sm:border-r lg:border-l border-gray-300 sm:rounded-r-xl lg:rounded-l-xl overflow-hidden"
  >
    <h1 class="text-[30px] font-bold text-center py-8">Proximamente...</h1>
  </main>
</Layout>
