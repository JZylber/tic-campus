---
import Layout from "../../layouts/Layout.astro";
---

<Layout>
  <div class="flex flex-col items-center grow gap-y-4">
    <h1 class="text-[30px] md:text-[36px] font-bold pt-4 pb-2">
      Dashboard Docente
    </h1>
    <p><strong>Esta sección es solo para docentes</strong></p>
    <p>Seleccioná tu perfil para ingresar.</p>
    <div class="flex gap-x-12 justify-center items-center">
      <a
        class="flex rounded-lg w-60 h-16 justify-center items-center text-[16px] sm:text-[24px] bg-sh-purple !text-sh-black hover:bg-sh-light-purple hover:shadow transition-colors cursor-pointer"
        href="/tic-campus/dashboard/teacher"
      >
        <span>Docente</span>
      </a>
      <a
        class="flex rounded-lg w-60 h-16 justify-center items-center text-[16px] sm:text-[24px] bg-sh-purple !text-sh-black hover:bg-sh-light-purple hover:shadow transition-colors cursor-pointer"
        href="/tic-campus/dashboard/admin"
      >
        <span>Administrador</span>
      </a>
    </div>
  </div>
</Layout>
