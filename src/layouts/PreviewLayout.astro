---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Previsualizador de Artículos" } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="w-full min-h-screen font-sans">
    <slot />
  </body>
</html>
