---
import "../styles/global.css";

interface Props {
  dataSheetId?: string;
  xData?: string;
}

const { dataSheetId, xData } = Astro.props;
---

<script>
  import sectionData from "../scripts/alpine/data/section";
  import setAlpineData from "../scripts/alpine/setAlpineData";

  setAlpineData("sectionData", sectionData);
  type Crumb = { text: string; link: string };
  type Menu = Array<string>;
  setAlpineData("crumbsData", () => ({
    crumbs: [] as Array<Crumb>,
    menu: [] as Menu,
    init() {
      let leftovers = document.querySelectorAll(
        "#leftoverinformation a.breadcrumb",
      ) as NodeListOf<HTMLAnchorElement>;
      if (leftovers.length > 0) {
        leftovers.forEach((el) => {
          this.crumbs.push({ text: el.innerText, link: el.href });
        });
      }
      let menuLeftoverLinks = document.querySelectorAll(
        "#leftoverinformation ul a",
      ) as NodeListOf<HTMLAnchorElement>;
      if (menuLeftoverLinks.length > 0) {
        menuLeftoverLinks.forEach((el) => {
          // Replace i tags with span tags with class material-symbols-outlined
          let iTags = el.querySelectorAll("i");
          iTags.forEach((i) => {
            let span = document.createElement("span");
            span.classList.add("material-symbols-outlined");
            span.classList.add("text-[16px]");
            span.innerText = i.innerText;
            i.replaceWith(span);
          });
          this.menu.push(el.outerHTML);
        });
      }
    },
  }));
</script>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,100;0,300;0,400;0,700;0,900;1,100;1,300;1,400;1,700;1,900&family=Special+Elite&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined"
    />
    <title>TIC Campus</title>
  </head>
  <body class="w-full mx-auto">
    <div
      class="w-fill flex font-lato relative lg:gap-x-4"
      :class="{ 'h-[calc(100vh-64px-1rem)] sm:w-[95%] max-w-[1280px]': $store.pageData.onCampus,'h-screen': !$store.pageData.onCampus }"
      x-data=`{...sectionData(),...${xData ?? '{}'}}`
      x-init=`$store.pageData.setDataSheetId("${dataSheetId??""}")`
    >
      <slot />
    </div>
  </body>
</html>
