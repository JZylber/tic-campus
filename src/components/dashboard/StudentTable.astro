---
import Loader from "../loader/Loader.astro";

import Select from "../../components/misc/select/Select.astro";
---

<script>
  import type { AlpineStudentStore } from "../../scripts/alpine/stores/student";
  import { fetchStudents } from "../../scripts/APIcalls/dashboard";
  type Students = Awaited<ReturnType<typeof fetchStudents>>;
  type Student = Students[number];
  type CourseEnrollment = Student["courses"][number];

  Alpine.data("studentsPage", () => ({
    loading: true,
    students: [] as Students,
    courses: [{ value: "", label: "Todos" }],
    years: [{ value: NaN, label: "Todos" }],
    filter: { course: "", text: "", year: NaN },
    selectedStudent: {
      student: null as Student | null,
      selectedCourse: null as CourseEnrollment | null,
      get subjectsForCourse() {
        if (!this.student || !this.selectedCourse) return [];
        const courseId = this.selectedCourse.courseId;
        return this.student.subjects.filter((s) => s.id_course === courseId);
      },
    },
    init() {
      fetchStudents().then((students) => {
        this.students = students.sort((a, b) => {
          const aMaxYear = a.courses.length
            ? Math.max(...a.courses.map((c) => c.year))
            : 0;
          const bMaxYear = b.courses.length
            ? Math.max(...b.courses.map((c) => c.year))
            : 0;
          if (aMaxYear !== bMaxYear) return bMaxYear - aMaxYear;
          if (a.surname < b.surname) return -1;
          if (a.surname > b.surname) return 1;
          return 0;
        });
        this.courses = [{ value: "", label: "Todos" }].concat(
          [
            ...new Set(
              this.students.flatMap((s) => s.courses.map((c) => c.course)),
            ),
          ]
            .sort()
            .map((course) => ({ value: course, label: course })),
        );
        this.years = [{ value: NaN, label: "Todos" }].concat(
          [
            ...new Set(
              this.students.flatMap((s) => s.courses.map((c) => c.year)),
            ),
          ]
            .sort((a, b) => b - a)
            .map((year) => ({ value: year, label: year.toString() })),
        );
        this.filter.year = this.years[0].value;
        this.filter.course = this.courses[0].value;
        this.filter.text = "";
        this.loading = false;
      });
    },
    get filteredStudents() {
      return this.students
        .filter((s) => {
          let courseFilter = true;
          let textFilter = true;
          let yearFilter = true;
          const normalizedText = this.filter.text
            .toLowerCase()
            .normalize("NFD")
            .replace(/[̀-ͯ]/g, "");
          if (this.filter.text !== "") {
            textFilter =
              s.name
                .toLowerCase()
                .normalize("NFD")
                .replace(/[̀-ͯ]/g, "")
                .includes(normalizedText) ||
              s.surname
                .toLowerCase()
                .normalize("NFD")
                .replace(/[̀-ͯ]/g, "")
                .includes(normalizedText);
          }
          if (this.filter.course !== "") {
            courseFilter = s.courses.some((c) => c.course === this.filter.course);
          }
          if (!isNaN(this.filter.year)) {
            yearFilter = s.courses.some((c) => c.year === this.filter.year);
          }
          return yearFilter && textFilter && courseFilter;
        })
        .sort((a, b) => {
          const aMaxYear = a.courses.length
            ? Math.max(...a.courses.map((c) => c.year))
            : 0;
          const bMaxYear = b.courses.length
            ? Math.max(...b.courses.map((c) => c.year))
            : 0;
          if (aMaxYear !== bMaxYear) return bMaxYear - aMaxYear;
          if (a.surname < b.surname) return -1;
          if (a.surname > b.surname) return 1;
          return 0;
        });
    },
    selectStudent(student: Student) {
      this.selectedStudent.student = student;
      this.selectedStudent.selectedCourse = null;
    },
    selectCourse(course: CourseEnrollment) {
      const studentStore = Alpine.store("student") as AlpineStudentStore;
      studentStore.setStudent(
        this.selectedStudent.student!.name,
        this.selectedStudent.student!.surname,
        course.course,
        this.selectedStudent.student!.id,
      );
      studentStore.setSubject("");
      this.selectedStudent.selectedCourse = course;
    },
  }));
</script>
<div class="w-full flex justify-center py-4" x-data="studentsPage()">
  <Loader show="loading" />
  <dialog
    class="m-auto w-1/2 h-3/4 rounded-2xl border-2 border-gray-300 p-4"
    x-ref="subjectsDialog"
  >
    <div class="flex justify-end">
      <span
        class="material-symbols-outlined cursor-pointer"
        @click="$refs.subjectsDialog.close()">cancel</span
      >
    </div>

    <!-- State A: course list -->
    <div x-show="!selectedStudent.selectedCourse" class="flex flex-col h-[calc(100%-2rem)]">
      <h2 class="text-2xl font-bold text-center mb-4">
        Cursos de
        <span x-text="selectedStudent.student?.name"></span>
        <span x-text="selectedStudent.student?.surname"></span>
      </h2>
      <div class="overflow-y-scroll flex flex-col gap-4 p-4 items-center">
        <template x-for="course in (selectedStudent.student?.courses ?? [])">
          <button
            @click="selectCourse(course)"
            class="flex gap-x-4 py-2 px-6 rounded-xl bg-gray-300 cursor-pointer hover:shadow-lg w-fit text-[16px] text-sh-dark-gray"
          >
            <span x-text="`${course.course} - ${course.year}`"></span>
          </button>
        </template>
      </div>
    </div>

    <!-- State B: subject list -->
    <div x-show="selectedStudent.selectedCourse" class="flex flex-col h-[calc(100%-2rem)]">
      <div class="flex items-center mb-4 gap-2">
        <span
          class="material-symbols-outlined cursor-pointer"
          @click="selectedStudent.selectedCourse = null">arrow_back</span
        >
        <h2 class="text-2xl font-bold text-center flex-1">
          Materias —
          <span x-text="selectedStudent.selectedCourse?.course"></span>
          (<span x-text="selectedStudent.selectedCourse?.year"></span>)
        </h2>
      </div>
      <div class="overflow-y-scroll flex flex-col gap-4 p-4 items-center">
        <template x-for="subject in selectedStudent.subjectsForCourse">
          <a
            :href="`${$store.pageData.dataURL}/${selectedStudent.selectedCourse?.year}/${subject.subject}/${selectedStudent.selectedCourse?.course}`"
            class="flex gap-x-4 py-2 px-4 rounded-xl bg-gray-300 cursor-pointer hover:shadow-lg w-fit"
          >
            <span class="text-[16px] text-sh-dark-gray" x-text="subject.subject"></span>
          </a>
        </template>
      </div>
    </div>
  </dialog>

  <div class="w-full flex flex-col gap-y-4" x-show="!loading">
    <div class="flex w-full gap-x-8">
      <div class={`flex flex-col items-center md:items-start gap-2 px-4`}>
        <label
          class="text-center md:text-left text-sh-dark-gray text-[16px] font-semibold"
          >Nombre y Apellido</label
        >
        <div
          class="flex justify-between items-stretch w-full max-w-[200px] h-[44px] rounded-xl text-sh-dark-gray text-[16px] border-2 border-sh-gray"
        >
          <div class="flex items-center basis-0 grow px-2">
            <input class="w-full focus:outline-0" x-model="filter.text" />
          </div>
          <div class="flex items-center">
            <span
              class="material-symbols-outlined text-[24px] text-sh-dark-gray px-2"
            >
              search
            </span>
          </div>
        </div>
      </div>
      <Select
        title="Curso"
        xModel="filter.course"
        options="courses"
        className="min-w-48"
      />
      <Select
        title="Año"
        xModel="filter.year"
        options="years"
        className="min-w-48"
      />
    </div>
    <table class="w-full">
      <thead class="bg-sh-black text-gray-50 text-lg font-semibold">
        <tr>
          <th class="px-4 py-2">Nombre</th>
          <th class="px-4 py-2">Apellido</th>
          <th class="px-4 py-2">DNI</th>
          <th class="px-4 py-2">Email</th>
          <th class="px-4 py-2">Editar</th>
        </tr>
      </thead>
      <tbody>
        <template x-for="student in filteredStudents">
          <tr
            class="border-b-2 border-gray-300 hover:bg-gray-300 cursor-pointer"
            @click="selectStudent(student); $refs.subjectsDialog.showModal()"
          >
            <td class="px-4 py-2" x-text="student.name"></td>
            <td class="px-4 py-2" x-text="student.surname"></td>
            <td class="px-4 py-2" x-text="student.dni"></td>
            <td class="px-4 py-2" x-text="student.email"></td>
            <td class="px-4 py-2 text-center">
              <button
                @click.stop=""
                class="material-symbols-outlined text-[20px] text-sh-dark-gray hover:text-black"
              >edit</button>
            </td>
          </tr>
        </template>
      </tbody>
    </table>
  </div>
</div>
