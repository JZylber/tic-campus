---
import Loader from "../../loader/Loader.astro";
import Select from "../../misc/select/Select.astro";
import Radio from "../../misc/radio/Radio.astro";
import TimetableGrid from "../../sections/timetable/TimetableGrid.astro";
import SlotDialog from "./SlotDialog.astro";
---

<script>
  import setAlpineData from "../../../scripts/alpine/setAlpineData";
  import offeringTimeSlotsPageData from "../../../scripts/alpine/data/offeringTimeSlotsPage";

  setAlpineData("offeringTimeSlotsPage", offeringTimeSlotsPageData);
</script>
<div class="w-full flex justify-center py-4" x-data="offeringTimeSlotsPage()">
  <Loader show="loading" />
  <SlotDialog />

  <div class="w-full flex flex-col gap-y-4 px-4" x-show="!loading">
    <div class="flex flex-col gap-y-4 py-2 md:flex-row md:items-end md:gap-x-8 w-full">
      <Radio title="Año escolar" xModel="level" options="levelOptions" className="w-full md:w-1/4" />
      <Select title="Año" xModel="year" options="yearOptions" className="w-full md:w-32" />
      <Select
        title="Materia"
        xModel="offeringId"
        options="offeringOptions"
        className="w-full md:w-72"
        disabled="isNaN(level)"
      />
    </div>

    <span class="text-sh-dark-gray text-sm" x-show="isNaN(level)">Elegí el año escolar.</span>
    <span
      class="text-sh-dark-gray text-sm"
      x-show="!isNaN(level) && isNaN(offeringId)"
      >Elegí la materia.</span
    >

    <template x-if="!isNaN(level) && !isNaN(offeringId)">
      <div
        class="relative"
        @timetable-cell-click="openSlotDialog($event.detail); $refs.slotDialog.showModal()"
      >
        <TimetableGrid editable={true} />
      </div>
    </template>

    <span class="text-red-500 text-sm" x-text="error ?? ''" x-show="error"></span>
  </div>
</div>
