---
import Dialog from "../../misc/dialog/Dialog.astro";
---

<Dialog xRef="slotDialog" className="w-full max-w-md p-6">
  <h2 class="text-2xl font-bold mb-2">
    <span x-text="slotDialog.mode === 'create' ? 'Agregar horario' : 'Editar horario'"></span>
  </h2>
  <p class="text-sh-dark-gray mb-6">
    <span x-text="slotDialog.day"></span> &mdash; Bloque <span x-text="slotDialog.block"></span>
  </p>

  <div class="flex flex-col gap-4">
    <div class="flex flex-col gap-1">
      <label class="text-sm font-semibold text-sh-dark-gray">Aula (opcional)</label>
      <input
        type="text"
        x-model="slotDialog.classroom"
        placeholder="Aula"
        class="border-2 border-sh-gray rounded-xl px-3 py-2 focus:outline-sh-purple"
      />
    </div>

    <div class="flex justify-between items-center mt-2">
      <span class="text-red-500 text-sm" x-text="error ?? ''" x-show="error"></span>
      <div class="ml-auto flex gap-2">
        <button
          x-show="slotDialog.mode === 'edit'"
          @click="deleteSlot().then((ok) => { if (ok) $el.closest('dialog').close() })"
          class="px-4 py-2 bg-red-500 text-white rounded-xl hover:opacity-80 disabled:opacity-40 cursor-pointer"
          :disabled="saving"
          >Eliminar</button
        >
        <button
          @click="submitSlotDialog().then((ok) => { if (ok) $el.closest('dialog').close() })"
          class="px-4 py-2 bg-sh-black text-white rounded-xl hover:opacity-80 disabled:opacity-40 cursor-pointer"
          :disabled="saving"
          x-text="slotDialog.mode === 'create' ? 'Agregar' : 'Guardar'"
        ></button>
      </div>
    </div>
  </div>
</Dialog>
