---
interface Props {
  role: "teacher" | "admin" | "tutor";
}
const { role } = Astro.props;
const otherDashboards = [
  { key: "teacher", label: "Modo Docente", href: "/tic-campus/dashboard/teacher" },
  { key: "admin", label: "Modo Admin", href: "/tic-campus/dashboard/admin" },
  { key: "tutor", label: "Modo Tutor", href: "/tic-campus/dashboard/tutor" },
].filter((dashboard) => dashboard.key !== role);
---

<nav class="w-full bg-gray-50 border-b-2 border-gray-300 flex items-stretch">
  {
    role === "teacher" && (
      <>
        <a
          href="/tic-campus/dashboard/teacher"
          class="py-4 flex items-center justify-center w-40 hover:bg-gray-300 uppercase font-bold text-gray-700"
        >
          Notas
        </a>
        <a
          href="/tic-campus/dashboard/teacher/revision"
          class="py-4 flex items-center justify-center w-40 hover:bg-gray-300 uppercase font-bold text-gray-700"
        >
          Revisiones
        </a>
        <a
          href="/tic-campus/dashboard/teacher/horarios"
          class="py-4 flex items-center justify-center w-40 hover:bg-gray-300 uppercase font-bold text-gray-700"
        >
          Horarios
        </a>
      </>
    )
  }
  {
    role === "tutor" && (
      <>
        <a
          href="/tic-campus/dashboard/tutor"
          class="py-4 flex items-center justify-center w-40 hover:bg-gray-300 uppercase font-bold text-gray-700"
        >
          Horarios
        </a>
      </>
    )
  }
  {
    role === "admin" && (
      <>
        <a
          href="/tic-campus/dashboard/admin"
          class="py-4 flex items-center justify-center w-40 hover:bg-gray-300 uppercase font-bold text-gray-700"
        >
          Estudiantes
        </a>
        <a
          href="/tic-campus/dashboard/admin/materias"
          class="py-4 flex items-center justify-center w-40 hover:bg-gray-300 uppercase font-bold text-gray-700"
        >
          Materias
        </a>
        <a
          href="/tic-campus/dashboard/admin/avanzados"
          class="py-4 flex items-center justify-center w-40 hover:bg-gray-300 uppercase font-bold text-gray-700"
        >
          Avanzados
        </a>
        <a
          href="/tic-campus/dashboard/admin/horarios"
          class="py-4 flex items-center justify-center w-40 hover:bg-gray-300 uppercase font-bold text-gray-700"
        >
          Horarios
        </a>
      </>
    )
  }
  <div class="ml-auto flex items-stretch border-l-2 border-gray-300">
    {
      otherDashboards.map((dashboard) => (
        <a
          x-show="$store.currentUser.role === 'ADMIN'"
          x-cloak
          href={dashboard.href}
          class="flex items-center px-4 bg-sh-purple !text-sh-black hover:bg-sh-light-purple transition-colors font-bold uppercase text-sm"
        >
          {dashboard.label}
        </a>
      ))
    }
    <a
      href="/tic-campus/"
      x-show="$store.currentUser.role === 'ADMIN' && $store.student.id !== ''"
      x-cloak
      class="flex items-center justify-end gap-x-4 px-4"
    >
      <span
        class="material-symbols-outlined !text-[30px]"
        x-text="$store.student.id === ''?'question_mark':'person'"></span>
      <div class="flex flex-col w-50 text-gray-700 text-[14px] md:text-[16px]">
        <span x-text="$store.student.name"></span>
        <span x-text="$store.student.surname"></span>
      </div>
    </a>
  </div>
</nav>
