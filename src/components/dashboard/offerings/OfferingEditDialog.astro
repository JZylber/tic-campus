---
import Dialog from "../../misc/dialog/Dialog.astro";
import Select from "../../misc/select/Select.astro";
---

<Dialog xRef="editOfferingDialog" className="w-1/2 p-6 overflow-y-auto max-h-[75vh]">
  <h2 class="text-2xl font-bold mb-2">Editar materia</h2>
  <p class="text-sh-dark-gray mb-6" x-text="editForm.offering?.subjectName ?? ''"></p>

  <div class="flex flex-col gap-4">
    <Select title="Semestre" xModel="editForm.semester" options="semesterOptions" />

    <div class="flex flex-col gap-1">
      <label class="text-sm font-semibold text-sh-dark-gray">Nombre (opcional)</label>
      <input
        type="text"
        x-model="editForm.name"
        placeholder="Nombre"
        class="border-2 border-sh-gray rounded-xl px-3 py-2 focus:outline-sh-purple"
      />
    </div>

    <div class="flex flex-col gap-2">
      <h3 class="text-lg font-semibold border-b border-gray-200 pb-1">
        Cursos (Nivel <span x-text="activeLevel"></span>° &mdash; <span x-text="year"></span>)
      </h3>
      <template x-for="course in editCourses" :key="course.id">
        <label class="flex items-center gap-2 py-1 cursor-pointer">
          <input
            type="checkbox"
            class="accent-sh-purple w-5 h-5"
            :checked="editForm.courseIds.includes(course.id)"
            @change="toggleEditCourse(course.id)"
          />
          <span x-text="course.name"></span>
        </label>
      </template>
    </div>

    <div class="flex justify-between items-center mt-2">
      <span class="text-red-500 text-sm" x-text="error ?? ''" x-show="error"></span>
      <button
        @click="saveEdit().then((ok) => { if (ok) $el.closest('dialog').close(); })"
        class="ml-auto px-4 py-2 bg-sh-black text-white rounded-xl hover:opacity-80 disabled:opacity-40 cursor-pointer"
        :disabled="saving || editForm.courseIds.length === 0"
        >Guardar</button
      >
    </div>
  </div>
</Dialog>
