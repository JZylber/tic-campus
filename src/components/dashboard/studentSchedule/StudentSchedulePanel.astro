---
import Loader from "../../loader/Loader.astro";
import Select from "../../misc/select/Select.astro";
import Radio from "../../misc/radio/Radio.astro";
import Toggle from "../../misc/toggle/Toggle.astro";
import TimetableGrid from "../../sections/timetable/TimetableGrid.astro";
---

<script>
  import setAlpineData from "../../../scripts/alpine/setAlpineData";
  import studentSchedulePageData from "../../../scripts/alpine/data/studentSchedulePage";

  setAlpineData("studentSchedulePage", studentSchedulePageData);
</script>
<div class="w-full flex justify-center py-4" x-data="studentSchedulePage()">
  <Loader show="loading" />

  <div class="w-full flex flex-col gap-y-4 px-4" x-show="!loading">
    <div class="flex flex-col gap-y-4 py-2 md:flex-row md:items-end md:gap-x-8 w-full">
      <Radio title="Año escolar" xModel="level" options="levelOptions" className="w-full md:w-1/4" />
      <Select
        title="Curso"
        xModel="courseId"
        options="courseOptions"
        className="w-full md:w-40"
        disabled="isNaN(level)"
      />
      <Select
        title="Estudiante"
        xModel="studentId"
        options="studentOptions"
        className="w-full md:w-72"
        disabled="isNaN(courseId)"
      />
    </div>
    <div class="flex flex-col gap-y-4 pb-2 md:flex-row md:items-end md:gap-x-8 w-full">
      <Toggle
        title="Cuatrimestre"
        xModel="cuatrimestre"
        options="cuatrimestreOptions"
        className="w-full md:w-1/3"
      />
    </div>

    <span class="text-sh-dark-gray text-sm" x-show="isNaN(level)">Elegí el año escolar.</span>
    <span class="text-sh-dark-gray text-sm" x-show="!isNaN(level) && isNaN(courseId)"
      >Elegí el curso.</span
    >
    <span
      class="text-sh-dark-gray text-sm"
      x-show="!isNaN(courseId) && isNaN(studentId)"
      >Elegí el estudiante.</span
    >

    <template x-if="!isNaN(studentId)">
      <TimetableGrid editable={false} />
    </template>
  </div>
</div>
