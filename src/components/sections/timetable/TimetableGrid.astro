---
import Loader from "../../loader/Loader.astro";
import TimetableCell from "./TimetableCell.astro";
import { DAYS, getGridBlocks, getGridCells } from "../../../scripts/timetableLayout";

interface Props {
  // Enables click/keyboard interaction on every cell (filled or empty) so a
  // caller (e.g. an admin editor) can react to `timetable-cell-click`
  // events. View-only callers should leave this false.
  editable?: boolean;
  // Alpine expression (or boolean) controlling whether the "Propios" tab is
  // selectable. Callers that can't tell who "Propios" would mean (e.g. no
  // student identified) pass a falsy expression to grey it out and force
  // the first non-personalized tab. Defaults to always-available, matching
  // prior behavior.
  personalizedAvailable?: string | boolean;
  // Alpine expression (or literal array) for the non-personalized tabs —
  // one per distinct schedule "view" a caller wants to expose (e.g. one per
  // rotation group). Defaults to a single "Rotación" tab, reproducing the
  // old fixed Propios/Rotación toggle for every caller that doesn't opt in.
  tabs?: string | Array<{ id: string; label: string }>;
  // Forces the tab switcher to render even with a single non-personalized
  // tab and no seminars — needed by callers where "Propios" already differs
  // meaningfully from that single tab (e.g. Proyecto, where "Propios" only
  // shows the student's own rotation group).
  alwaysShowTabs?: string | boolean;
}

const {
  editable = false,
  personalizedAvailable = true,
  tabs = [{ id: "rotacion", label: "Rotación" }],
  alwaysShowTabs = false,
} = Astro.props;
const personalizedAvailableExpr =
  typeof personalizedAvailable === "string"
    ? personalizedAvailable
    : JSON.stringify(personalizedAvailable);
const tabsExpr = typeof tabs === "string" ? tabs : JSON.stringify(tabs);
const alwaysShowTabsExpr =
  typeof alwaysShowTabs === "string" ? alwaysShowTabs : JSON.stringify(alwaysShowTabs);

const blocks = getGridBlocks();
const cells = getGridCells();
const daysJson = JSON.stringify(DAYS);
---

<div
  class="flex flex-col gap-y-4"
  x-data="{personalized: false, canPersonalize: true, tabsList: [], activeTab: null, alwaysShowTabs: false, visibleSeminars: []}"
  x-effect={`
    canPersonalize = ${personalizedAvailableExpr};
    if (!canPersonalize) personalized = false;
    tabsList = ${tabsExpr};
    alwaysShowTabs = ${alwaysShowTabsExpr};
    if (!tabsList.some((t) => t.id === activeTab)) activeTab = tabsList[0]?.id ?? null;
    visibleSeminars = getSeminars(personalized, activeTab) ?? [];
  `}
>
  <Loader show="state === 'loading'" />

  <template x-if="state === 'error'">
    <div
      class="flex-grow flex justify-center items-center text-[20px] md:text-[24px] text-sh-red"
    >
      Ocurrió un error al cargar los horarios.
    </div>
  </template>

  <template x-if="state === 'empty'">
    <div
      class="flex-grow flex justify-center items-center text-[20px] md:text-[24px]"
    >
      Proximamente...
    </div>
  </template>

  <template x-if="state === 'ready' && visibleSeminars.length > 0">
    <div class="flex flex-col gap-y-2 pt-2 pb-4 border-y-2 border-gray-400">
      <h2 class="text-center text-[20px] md:text-[24px] font-bold">
        Seminarios Avanzados
      </h2>
      <div
        class="flex flex-col gap-2 items-center md:flex-row md:justify-center md:gap-x-8"
      >
        <template x-for="seminar in visibleSeminars">
          <div
            class="flex text-[16px] md:text-[18px] rounded-lg w-full max-w-56 md:w-48 h-8 md:h-10 justify-center items-center"
            :class="subjectColorClass(seminar)"
          >
            <span x-text="seminar"></span>
          </div>
        </template>
      </div>
    </div>
  </template>

  <template x-if="state === 'ready'">
    <div class="flex flex-col gap-y-4">
      <template x-if="visibleSeminars.length > 0 || tabsList.length > 1 || alwaysShowTabs">
        <div class="flex justify-center w-full" x-init="personalized = canPersonalize">
          <div
            class="rounded-lg bg-gray-400 text-[16px] font-bold text-gray-300 inline-flex justify-center items-center h-10 overflow-hidden"
            role="tablist"
            aria-label="Vista de horario"
          >
            <button
              type="button"
              role="tab"
              :aria-selected="personalized"
              :aria-disabled="!canPersonalize"
              :tabindex="canPersonalize ? 0 : -1"
              class="px-4 h-full flex justify-center items-center transition-colors"
              :class="{'bg-sh-purple text-white': personalized, 'cursor-pointer': canPersonalize, 'cursor-not-allowed opacity-50': !canPersonalize}"
              @click="canPersonalize && (personalized = true)"
            >
              Propios
            </button>
            <template x-for="tab in tabsList" :key="tab.id">
              <button
                type="button"
                role="tab"
                :aria-selected="!personalized && activeTab === tab.id"
                class="px-4 h-full flex justify-center items-center cursor-pointer transition-colors"
                :class="{'bg-sh-purple text-white': !personalized && activeTab === tab.id}"
                @click="personalized = false; activeTab = tab.id"
                x-text="tab.label"
              ></button>
            </template>
          </div>
        </div>
      </template>

      <!-- Desktop: full weekly grid -->
      <div
        class="hidden md:grid grid-cols-[40px_repeat(5,minmax(0,1fr))] grid-rows-[32px_repeat(3,minmax(96px,1fr))_12px_repeat(3,minmax(96px,1fr))] items-stretch border-gray-400 border-2 w-full max-w-full rounded-xl overflow-hidden gap-[1px] bg-gray-400"
        role="grid"
        aria-label="Horario semanal"
      >
        <div
          class="grid grid-cols-subgrid grid-rows-1 col-span-full bg-gray-300 text-gray-600 text-[16px] font-bold items-stretch"
        >
          {
            DAYS.map((day, index) => (
              <div
                class="flex items-center justify-center"
                style={`grid-column-start: ${index + 2};`}
                role="columnheader"
                aria-colindex={index + 2}
              >
                {day}
              </div>
            ))
          }
        </div>
        <div
          class="grid grid-rows-subgrid grid-cols-subgrid col-start-1 row-start-2 -row-end-1 bg-gray-50"
        >
          {
            blocks.map(({ block, row }) => (
              <div
                class="flex justify-center items-center"
                style={`grid-row-start: ${row};`}
                role="rowheader"
                aria-rowindex={row}
              >
                {block}
              </div>
            ))
          }
        </div>
        <div
          class="grid grid-cols-subgrid grid-rows-subgrid row-start-2 -row-end-1 col-start-2 -col-end-1"
        >
          <div class="row-start-4 bg-gray-300 col-span-full" aria-hidden="true"></div>
          {
            cells.map(({ row, col, day, block }) => (
              <TimetableCell
                row={row}
                col={col}
                day={day}
                block={block}
                editable={editable}
                class="bg-gray-50 flex flex-col overflow-hidden"
                style={`grid-column-start: ${col}; grid-row-start: ${row};`}
              >
                <template x-for="{subject,room,teacher,conflict} in slotData">
                  <div
                    class="flex flex-col items-center h-full gap-y-0.5 py-1 transition-opacity"
                    :class="[slotClasses(subject), conflict && 'ring-2 ring-inset ring-sh-red']"
                  >
                    <span
                      class="text-[10px] md:text-[11px] font-bold text-sh-red"
                      x-show="conflict"
                      x-cloak
                      >¡Conflicto!</span
                    >
                    <span
                      class="text-[14px] md:text-[16px] font-semibold"
                      x-text="subject"></span>
                    <span
                      class="text-[12px] md:text-[14px]"
                      :class="subjectSecondaryTextClass(subject)"
                      x-text="room"></span>
                    <span
                      class="text-[12px] md:text-[14px]"
                      :class="subjectSecondaryTextClass(subject)"
                      x-text="teacher"></span>
                  </div>
                </template>
              </TimetableCell>
            ))
          }
        </div>
      </div>

      <!-- Mobile: single-day carousel -->
      <div
        class="flex flex-col md:hidden border-gray-400 border-2 w-full rounded-xl overflow-hidden bg-gray-300 text-gray-600 text-[14px] md:text-[16px] font-bold"
        x-data={`{day: 0, days: ${daysJson}}`}
        x-init="day = new Date().getDay() - 1; if (day < 0 || day >= 5) day = 0"
        role="grid"
        aria-label="Horario diario"
      >
        <div
          class="flex py-2 w-full divide-x divide-gray-400 border-b-2 border-gray-400"
        >
          <button
            type="button"
            class="w-10 flex items-center justify-center"
            @click="day = Math.max(day - 1, 0)"
            :aria-disabled="day === 0"
            aria-label="Día anterior"
          >
            <span
              class="material-symbols-outlined"
              :class="{'text-gray-400': day === 0}"
              aria-hidden="true">chevron_left</span
            >
          </button>
          <div class="grow flex justify-center items-center" aria-live="polite">
            <span x-text="days[day]"></span>
          </div>
          <button
            type="button"
            class="w-10 flex items-center justify-center"
            @click="day = Math.min(day + 1, 4)"
            :aria-disabled="day === 4"
            aria-label="Día siguiente"
          >
            <span
              class="material-symbols-outlined"
              :class="{'text-gray-400': day === 4}"
              aria-hidden="true">chevron_right</span
            >
          </button>
        </div>
        <div
          class="w-full grid grid-cols-[40px_1fr] grid-rows-[repeat(3,minmax(64px,1fr))_12px_repeat(3,minmax(64px,1fr))] bg-gray-400 gap-0.5 items-stretch"
          x-swipe:left="day = Math.min(day + 1, 4)"
          x-swipe:right="day = Math.max(day - 1, 0)"
        >
          {
            blocks.map(({ block, row }) => (
              <div
                class="bg-gray-50 flex justify-center items-center text-[20px] font-bold"
                style={`grid-row-start: ${row};`}
                role="rowheader"
                aria-rowindex={row}
              >
                {block}
              </div>
            ))
          }
          <div class="bg-gray-400 row-start-4 col-span-full" aria-hidden="true"></div>
          {
            blocks.map(({ row, block }) => (
              <div class="bg-gray-50 w-full overflow-hidden" style={`grid-row-start: ${row};`}>
                <div
                  class="w-[500%] flex transition-transform"
                  :style="`transform: translateX(${day * -20}%)`"
                >
                  {
                    DAYS.map((dayName, index) => (
                      <TimetableCell
                        row={row}
                        col={index + 1}
                        day={dayName}
                        block={block}
                        editable={editable}
                        class="flex flex-col w-1/5 overflow-hidden"
                      >
                        <template x-for="{subject,room,teacher,conflict} in slotData">
                          <div
                            class="flex flex-col items-center h-full gap-y-0.5 py-1"
                            :class="[slotClasses(subject), conflict && 'ring-2 ring-inset ring-sh-red']"
                          >
                            <span
                              class="text-[10px] font-bold text-sh-red"
                              x-show="conflict"
                              x-cloak
                              >¡Conflicto!</span
                            >
                            <span class="text-[14px]">
                              <span
                                class="font-semibold"
                                x-text="subject"></span>
                              <span
                                :class="subjectSecondaryTextClass(subject)"
                                x-text="' - ' + teacher"
                              ></span>
                            </span>
                            <span
                              class="text-[12px] md:text-[14px]"
                              :class="subjectSecondaryTextClass(subject)"
                              x-text="room"></span>
                          </div>
                        </template>
                      </TimetableCell>
                    ))
                  }
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </template>
</div>
