---
import Error from "../../articles/error/Error.astro";
import Loader from "../../loader/Loader.astro";

interface Props {
  open: string;
  articleURL: string;
  content: string;
  course: string;
}

const { open, articleURL, content, course } = Astro.props;
---

<script>
  import type { AlpineComponent } from "alpinejs";
  import setAlpineData from "../../../scripts/alpine/setAlpineData";
  import type { Content } from "../../../scripts/types";
  import { renderArticleInto } from "../../../scripts/articles/renderArticle";

  setAlpineData(
    "articleData",
    () =>
      ({
        loading: true,
        error: false,
        errorMessage: "",
        async updateArticle(content: Content, articleURL: string) {
          if (content !== null) {
            this.loading = true;
            try {
              const response = await fetch(articleURL);
              if (!response.ok) {
                let message = "";
                if (response.status == 404) {
                  message =
                    "(404) No se encontró la página para '" +
                    content.name +
                    "'";
                } else if (response.status == 500) {
                  message = "(500) Error interno del servidor";
                } else {
                  message = "(" + response.status + ") Error desconocido";
                }
                throw new Error(message);
              }
              const rawHTML = await response.text();
              await this.initArticle(rawHTML);
              this.error = false;
            } catch (err) {
              this.error = true;
              this.errorMessage = err as string;
            } finally {
              this.loading = false;
            }
          }
        },
        async initArticle(rawHTML: string) {
          await renderArticleInto(this.$refs.content as HTMLElement, rawHTML);
        },
      }) as AlpineComponent<{
        loading: boolean;
        error: boolean;
        errorMessage: string;
        updateArticle: (content: Content, articleURL: string) => Promise<void>;
        initArticle: (rawHTML: string) => Promise<void>;
      }>,
  );
</script>

<article
  x-show={`currentSection === 'actividades' && ${open} && ${content} !== null`}
  x-data="articleData()"
  class="absolute top-0 left-0 w-full h-full max-h-full bg-gray-50 flex flex-col pb-4 px-8 overflow-y-auto scrollbar"
  x-transition:enter="transition ease-in duration-500"
  x-transition:enter-start="translate-x-full border-l border-gray-400"
  x-transition:enter-end="translate-x-0 border-l border-gray-400"
  x-transition:leave="transition ease-out duration-500"
  x-transition:leave-start="translate-x-0 border-l border-gray-400"
  x-transition:leave-end="translate-x-full border-l border-gray-400"
  x-effect={`updateArticle(${content}, ${articleURL})`}
>
  <div
    class="flex w-full items-center py-4 mb-4 border-b-2 border-gray-300 sticky top-0 bg-gray-50 z-10 gap-x-4"
  >
    <div
      x-on:click={`${open} = false`}
      class="border-gray-400 border-2 p-2 rounded-xl cursor-pointer flex justify-center items-center gap-x-3 hover:shadow-md"
    >
      <span
        x-text="'arrow_back'"
        class="material-symbols-outlined text-[20px]! sm:text-[24px]!"></span>
      <span class="max-sm:hidden">Volver</span>
    </div>
    <template
      x-if={`${content} && ${content}.repositoryURL && ${content}.repositoryURL !== ''`}
    >
      <a
        class="bg-sh-purple border-2 border-sh-dark-gray p-2 max-sm:aspect-square rounded-xl cursor-pointer flex justify-center gap-x-3 sm:w-36 items-center hover:shadow-md"
        x-bind:href={`${content}.repositoryURL`}
        target="_blank"
      >
        <span class="max-sm:hidden">Repositorio</span>
        <svg
          class="w-[20px] h-[20px] sm:w-[24px] sm:h-[24px]"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
          fill="currentColor"
        >
          <path
            d="M2.5 18.5C2.5 20.43 4.07 22 6 22s3.5-1.57 3.5-3.5c0-1.58-1.06-2.903-2.5-3.337v-3.488c.244.273.509.527.813.744 1.18.844 2.617 1.098 3.918 1.098.966 0 1.853-.14 2.506-.281a3.5 3.5 0 0 0 3.264 2.265c1.93 0 3.5-1.57 3.5-3.5s-1.57-3.5-3.5-3.5a3.5 3.5 0 0 0-3.404 2.718c-1.297.321-3.664.616-5.119-.426-.666-.477-1.09-1.239-1.306-2.236C8.755 7.96 9.5 6.821 9.5 5.5 9.5 3.57 7.93 2 6 2S2.5 3.57 2.5 5.5c0 1.58 1.06 2.903 2.5 3.337v6.326c-1.44.434-2.5 1.757-2.5 3.337zm15-8c.827 0 1.5.673 1.5 1.5s-.673 1.5-1.5 1.5S16 12.827 16 12s.673-1.5 1.5-1.5zm-10 8c0 .827-.673 1.5-1.5 1.5s-1.5-.673-1.5-1.5S5.173 17 6 17s1.5.673 1.5 1.5zm-3-13C4.5 4.673 5.173 4 6 4s1.5.673 1.5 1.5S6.827 7 6 7s-1.5-.673-1.5-1.5z"
          ></path>
        </svg>
      </a>
    </template>
    <template
      x-if={`${content} && ${content}.handInURL && ${content}.handInURL !== ''`}
    >
      <a
        class="bg-sh-purple border-2 border-sh-dark-gray p-2 max-sm:aspect-square rounded-xl cursor-pointer flex justify-center gap-x-3 sm:w-36 items-center hover:shadow-md"
        x-bind:href={`${content}.handInURL`}
        target="_blank"
      >
        <span class="max-sm:hidden">Entrega</span>
        <span class="material-symbols-outlined text-[20px]! sm:text-[24px]!">
          move_to_inbox
        </span>
      </a>
    </template>
    <template
      x-if={`${content} && ${content}.tutorURL && ${content}.tutorURL !== ''`}
    >
      <a
        class="bg-sh-purple border-2 border-sh-dark-gray p-2 max-sm:aspect-square rounded-xl cursor-pointer flex justify-center gap-x-3 sm:w-36 items-center hover:shadow-md"
        x-bind:href={`${content}.tutorURL`}
        target="_blank"
      >
        <span class="max-sm:hidden">Tutor IA</span>
        <span class="material-symbols-outlined text-[20px]! sm:text-[24px]!">
          robot
        </span>
      </a>
    </template>
  </div>
  <Loader show="loading" />
  <template x-if="error">
    <Error message="errorMessage" />
  </template>
  <div x-show="!(loading || error)" class="flex flex-col gap-y-4">
    <div class="flex flex-col md:flex-row gap-x-4 items-center">
      <template
        x-data="{imageLink: undefined}"
        x-if="imageLink"
        x-effect={`imageLink = (${content} && ${content}.imgURL)?? undefined`}
      >
        <img
          x-bind:src={`${content} !== null?${content}.imgURL:''`}
          alt="imagen actividad"
          class="rounded-xl overflow-hidden aspect-square w-36 md:w-40 object-cover border-2 border-sh-black"
        />
      </template>
      <div class="self-stretch flex flex-col justify-center gap-y-2">
        <h1
          x-text={`${content} ? ${content}.name : ''`}
          class="text-center md:text-left text-[36px] md:text-[40px] lg:text-[48px] font-bold"
        >
        </h1>
        <template
          x-if={`${content} && $store.student.course === '${course}' &&
              ((${content}.type === 'Actividad' &&
                $store.marks.classActivities.find(
                  (activity) => activity.id === ${content}.id
                )) ||
                (${content}.type === 'Trabajo Práctico' &&
                  ($store.marks.markedActivities.find(
                    (activity) => activity.id === ${content}.id
                  )) || $store.marks.classActivities.find(
                    (activity) => activity.id === ${content}.id
                  )))`}
        >
          <div
            class="flex justify-center md:justify-start w-full"
            x-data="{ passing: false, mark: -1, comment: '', redo: false }"
            x-effect={`
                  if(${content}.type === 'Actividad') {
                    const activity = $store.marks.classActivities.find(activity => activity.id === ${content}.id);
                    mark = -1;
                    passing = activity.done;
                    comment = activity.comment;
                    redo = activity.inRevision;
                  }
                  else if(${content}.type === 'Trabajo Práctico') {
                    const activityMark = $store.marks.markedActivities.find(mark => mark.id === ${content}.id);
                    const specialActivity = $store.marks.classActivities.find(activity => activity.id === ${content}.id);
                    if (activityMark) {
                      mark = activityMark.mark;
                      passing = mark >= 6;
                      comment = activityMark.comment;
                      redo = activityMark.inRevision;
                      }
                    else if(specialActivity) {
                      mark = -1;
                      passing = specialActivity.done;
                      comment = specialActivity.comment;
                      redo = specialActivity.inRevision;
                    }
                    }
                `}
          >
            <div
              class="py-2 px-3 rounded-full flex justify-center items-center gap-x-2 text-[16px] border"
              x-bind:class="{
                  'bg-sh-light-yellow text-sh-yellow border-sh-medium-yellow': redo,
                  'bg-sh-light-green text-sh-green border-sh-medium-green ': passing && !redo,
                  'bg-sh-light-red text-sh-red border-sh-medium-red': !passing && !redo,
                }"
            >
              <span
                x-bind:class="{
                  'material-symbols-outlined text-[20px]! md:text-[24px]!': redo || mark === -1,
                }"
                x-text="(() => {
                          if (redo) {
                            return 'more_horiz';
                          } else if(mark === -1) {
                            if(passing) {
                              return 'check';
                            }
                            else {
                              return 'close';
                            }
                          }
                          else {
                            return mark;
                          }
                        })()"
              ></span>
              <span
                x-text={`(() => {
                    if(redo) {
                      return 'En Revisión'
                    }
                    if(comment) {
                      return comment
                    }
                    else {
                      if(${content}.type === 'Actividad') {
                        if(passing) {
                          return 'Hecha'
                        }
                        else {
                          return 'Pendiente'
                        }
                      }
                      else {
                        if(passing) {
                          return 'Aprobado'
                        }
                        else {
                          return 'En Proceso'
                        }
                      }
                    }
                  })()`}></span>
            </div>
          </div>
        </template>
      </div>
    </div>
    <div x-ref="content" class="article-content"></div>
  </div>
</article>
