---
import { fetchSubjectStudents } from "../../../scripts/APIcalls/subjectData";
import Loader from "../../loader/Loader.astro";
import Select from "../../misc/select/Select.astro";

interface Props {
  subject: string;
  course: string;
  year: number;
}

const { subject, course, year } = Astro.props;

// Fetch students for the subject, course, and year. Sort them by surname  and then by name for better display in the form.
const students = (await fetchSubjectStudents(subject, course, year))
  .sort(
    (a, b) =>
      a.surname.localeCompare(b.surname) || a.name.localeCompare(b.name),
  )
  .map((student) => {
    return { ...student, id: student.id.toString() };
  });

const redoReasons = [
  { value: "", label: "Seleccioná un motivo" },
  { value: "Estaba sin hacer", label: "Estaba sin hacer" },
  { value: "Quedó incompleto", label: "Quedó incompleto" },
  { value: "Para aprobar", label: "Para aprobar" },
  { value: "Otro", label: "Otro" },
];
---

<script>
  import setAlpineData from "../../../scripts/alpine/setAlpineData";
  import redoData from "../../../scripts/alpine/data/redos";
  setAlpineData("redoData", redoData);
</script>

<dialog
  x-ref="form"
  class="w-screen h-screen m-auto md:w-3/4 md:h-5/6 rounded-lg border-2 border-sh-black"
>
  <div
    x-data=`redoData(${JSON.stringify(students)}, "${subject}", "${course}", ${year})`
    class="h-full w-full"
  >
    <Loader show="sendingRequest && !sentRequest" />
    <div
      class="flex flex-col w-full h-full overflow-y-scroll p-4"
      x-show="!sendingRequest && !sentRequest"
    >
      <div class="flex justify-between">
        <span
          class="font-bold text-[24px] md:text-[30px] uppercase text-sh-purple"
          >Beta</span
        >
        <div
          @click="reset();formOpen = false;"
          class="material-symbols-outlined text-[24px] text-sh-black cursor-pointer"
        >
          cancel
        </div>
      </div>
      <h2 class="font-semibold text-[30px] md:text-[36px] text-center">
        Formulario de Reentrega
      </h2>
      <p class="text-gray-600 text-[14px] md:text-[16px] text-justify">
        Completá el siguiente formulario para reentregar una actividad de clase
        o un trabajo práctico. Se tiene que completar una vez <strong
          >por actividad</strong
        > y <strong>por grupo/estudiante</strong> (dependiendo si el trabajo es individual
        o en grupo).
      </p>
      <div class="mt-4">
        <h3 class="font-semibold text-[18px] md:text-[20px]">Estudiantes</h3>
        <template x-if="missingFields.studentIds">
          <p class="text-sh-red text-[14px] md:text-[16px]">
            Tenés que seleccionar al menos un estudiante para solicitar la
            reentrega.
          </p>
        </template>
        <div class="flex gap-2 flex-wrap">
          <template x-for={`student in selectedStudents`} :key="student.id">
            <div
              class="rounded-full bg-sh-purple flex items-center gap-x-2 px-4 py text-sh-black"
            >
              <span x-text="student.surname + ', ' + student.name"></span>
              <span
                class="material-symbols-outlined !text-[16px] cursor-pointer"
                @click="studentIds = studentIds.filter(id => id !== student.id)"
                >close</span
              >
            </div>
          </template>
        </div>
        <div
          class="flex flex-col overflow-y-scroll rounded-xl border-2 border-sh-black max-h-[200px] mt-2"
        >
          <template x-for={`student in remainingStudents`} :key="student.id">
            <div
              class="flex items-center px-4 py-2 cursor-pointer even:bg-gray-200"
              @click="studentIds = [...studentIds, student.id]"
            >
              <span x-text="student.surname + ', ' + student.name"></span>
            </div>
          </template>
        </div>
      </div>
      <div class="mt-4">
        <template x-if="missingFields.activityId">
          <p class="text-sh-red text-[14px] md:text-[16px]">
            Tenés que seleccionar una actividad para solicitar la reentrega.
          </p>
        </template>
        <Select
          title="Actividad/Trabajo Práctico"
          xModel="activityId"
          options="[{value: '', label: 'Seleccioná una actividad'}].concat($store.course.getRedoableActivities().map(activity => {return {value: activity.id, label: activity.name}}))"
          className="max-w-96"
        />
      </div>
      <div class="mt-4">
        <template x-if="missingFields.reason">
          <p class="text-sh-red text-[14px] md:text-[16px]">
            Tenés que seleccionar un motivo para solicitar la reentrega.
          </p>
        </template>
        <Select
          title="Motivo de Reentrega"
          xModel="reason"
          options={redoReasons}
          className="max-w-96"
        />
      </div>
      <div class="mt-4">
        <h3 class="font-semibold text-[16px] md:text-[18px]">
          Extras (si corresponde)
        </h3>
        <textarea
          x-model="bonusTask"
          placeholder="Si agregaron extras especifiquen cuales. No los corrijo sino"
          class="w-full h-24 border-2 border-sh-gray rounded-xl p-2 resize-none focus:outline-sh-purple"
        ></textarea>
      </div>
      <div class="mt-4">
        <h3 class="font-semibold !text-[16px] md:!text-[18px]">Comentarios</h3>
        <textarea
          x-model="comment"
          placeholder="(opcional)"
          class="w-full h-24 border-2 border-sh-gray rounded-xl p-2 resize-none focus:outline-sh-purple"
        ></textarea>
      </div>
      <div class="flex items-center justify-center mt-4">
        <div
          @click="requestRedo()"
          class="w-full md:w-1/2 flex justify-center items-center rounded-xl gap-x-4 bg-sh-purple px-4 py-2 cursor-pointer hover:shadow-lg"
        >
          <span class="text-[24px]">Enviar</span>
          <span class="max-md:hidden material-symbols-outlined !text-[30px]"
            >send</span
          >
        </div>
      </div>
    </div>
    <div
      class="flex flex-col w-full h-full justify-center p-4"
      x-show="!sendingRequest && sentRequest"
    >
      <h2
        class="font-bold text-[30px] md:text-[36px] text-center"
        x-text="status.success ? 'Solicitud enviada con éxito' : 'Error al enviar la solicitud'"
      >
      </h2>
      <p class="text-[20px] md:text-[24px] text-center" x-text="status.message">
      </p>
      <div class="flex items-center justify-center mt-4 gap-2 flex-wrap">
        <div
          @click="formOpen = false; reset()"
          class="w-full md:w-1/2 flex justify-center items-center rounded-xl gap-x-4 bg-sh-purple px-4 py-2 cursor-pointer hover:shadow-lg"
        >
          <span class="text-[24px]">Enviar otro pedido</span>
          <span class="max-md:hidden material-symbols-outlined !text-[30px]"
            >arrow_top_left</span
          >
        </div>
        <div
          @click="reset(); formOpen = false;"
          class="w-full md:w-1/2 flex justify-center items-center rounded-xl gap-x-4 bg-sh-purple px-4 py-2 cursor-pointer hover:shadow-lg"
        >
          <span class="text-[24px]">Cerrar</span>
          <span class="max-md:hidden material-symbols-outlined !text-[30px]"
            >close</span
          >
        </div>
      </div>
    </div>
  </div>
</dialog>
