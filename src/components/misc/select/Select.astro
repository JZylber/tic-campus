---
interface Props {
  title: string;
  xModel: string;
  options:
    | Array<{
        value: any;
        label: string;
      }>
    | string;
  className?: string;
}

const { title, xModel, options, className } = Astro.props;
---

<div
  x-data={`{options: [], selectedOption: null}`}
  class={`flex flex-col items-center md:items-start gap-2 ${className}`}
  x-effect={`options=${typeof options === "string" ? options : JSON.stringify(options)};if(options.length > 0){${xModel} = options[0].value; selectedOption = options[0];}`}
>
  <label
    class="text-center md:text-left text-sh-dark-gray text-[16px] font-semibold"
    x-text={`'${title}'`}></label>
  <div class="relative w-full h-[44px]">
    <!-- NOTE: @click.stop is on the options list (x-show="open"), not the toggle container.
         This contains option-selection clicks within the Select component (preventing them
         from reaching ancestor @click handlers) while still letting the toggle container's
         clicks bubble to the window — which the @click.window close handler on sibling Selects depends on.
         @click.window with composedPath() is used instead of @click.outside so that this works inside shadow DOMs,
         where event retargeting breaks element.contains(event.target). -->
    <div
      x-data="{ open: false }"
      @click="open = !open"
      @click.window="if(!$event.composedPath().includes($el)) open = false"
      class="absolute bg-gray-50 overflow-hidden w-full flex flex-col rounded-xl text-sh-dark-gray text-[16px] border-2 border-sh-gray cursor-pointer"
      :class=`{'z-10': open}`
    >
      <div class="p-2 flex justify-between items-center gap-x-6">
        <span x-text="selectedOption ? selectedOption.label : ''"></span>
        <span
          class="material-symbols-outlined text-[24px] transition-transform"
          :class=`{
          'rotate-180': open,
          'rotate-90': !open}`
        >
          keyboard_arrow_up
        </span>
      </div>
      <div
        x-show="open"
        x-collapse
        class="border-t-2 border-sh-gray divide-y-2 divide-gray-300"
        @click.stop
      >
        <template x-for="option in options">
          <div
            class="p-2 hover:bg-gray-300"
            @click=`${xModel} = option.value; selectedOption = option; open = false`
          >
            <span x-text="option.label"></span>
          </div>
        </template>
      </div>
    </div>
  </div>
</div>
