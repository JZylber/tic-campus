---
import Home from "../sections/home/Home.astro";
import Activities from "../sections/activities/Activities.astro";
import Redos from "../sections/redo/Redos.astro";
import Program from "../sections/program/Program.astro";
import Material from "../sections/material/Material.astro";
import Navbar from "../navbar/Navbar.astro";
import Mark from "../sections/mark/Mark.astro";
import Queries from "../sections/queries/Queries.astro";

interface Props {
  subject: string;
  course: string;
  year: number;
}

const { subject, course, year } = Astro.props;

const items = [
  { name: "home", icon: "home", title: subject },
  { name: "actividades", icon: "school", title: "Actividades" },
  { name: "programa", icon: "event_note", title: "Programa" },
  { name: "material", icon: "construction", title: "Material" },
  { name: "consultas", icon: "support_agent", title: "Consultas" },
  // { name: "horarios", icon: "calendar_month", title: "Horarios" },
];
---

<Navbar course={course} subject={subject} items={items} />
<main
  class="relative grow bg-gray-50 border-y sm:border-r lg:border-l border-gray-300 sm:rounded-r-xl lg:rounded-l-xl overflow-hidden"
  x-init={`$store.course.setCourse('${course}');$store.student.getStudentData('${subject}',${year})`}
>
  <Home
    subject={subject}
    course={course}
    year={year}
    position={0}
    presentation={false}
  />
  <Activities subject={subject} course={course} year={year} position={1} />
  <Program subject={subject} year={year} position={2} />
  <Material subject={subject} year={year} course={course} position={3} />
  <Queries position={4} />
  <!-- <Timetable subject={subject} position={5} /> -->
  <!--  <Mark subject={subject} course={course} year={year} position={5} /> -->
</main>
